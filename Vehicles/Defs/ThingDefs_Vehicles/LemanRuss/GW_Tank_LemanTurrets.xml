	<Vehicles.VehicleTurretDef ParentName="VehicleTurretBase">
		<defName>GW_LemanRuss_BattleCannonTurret</defName>
		<label>Leman Russ Battle cannon</label>
		<description>Main turret upgrade\n\nA standard 120mm tank cannon. A solid, general-purpose weapon, capable of delivering hallowed ordnance from a great distance to devastating effect.\n\nIt is the default armament of the standard Leman Russ.</description>
		<turretType>Rotatable</turretType>
		<shotSound>Shot_TurretSniper</shotSound>
		<projectile>Bullet_LemanRuss_BattleCannon</projectile>
		<reloadTimer>4.0</reloadTimer>
		<warmUpTimer>4.0</warmUpTimer>
		<magazineCapacity>1</magazineCapacity>
		<chargePerAmmoCount>1</chargePerAmmoCount>
		<genericAmmo>true</genericAmmo>
		<hitFlags>IntendedTarget</hitFlags>
		<autoSnapTargeting>false</autoSnapTargeting>
		<rotationSpeed>1.5</rotationSpeed>
		<projectileOffset>3.0</projectileOffset>
		<projectileShifting>
			<li>-0.1</li>
		</projectileShifting>
		<minRange>5</minRange>
		<maxRange>59.9</maxRange>
		<recoil>
			<distanceTotal>0.25</distanceTotal>
			<distancePerTick>0.1</distancePerTick>
			<speedMultiplierPostRecoil>0.25</speedMultiplierPostRecoil>
		</recoil>
		<attachProjectileFlag>GW_Tank</attachProjectileFlag>
		<fireModes>
			<li>
				<shotsPerBurst>1</shotsPerBurst>
				<ticksBetweenShots>12</ticksBetweenShots>
				<ticksBetweenBursts>60</ticksBetweenBursts>
				<label>Single</label>
				<texPath>UI/Gizmos/FireRate_Single</texPath>
			</li>
		</fireModes>
		<graphicData>
			<texPath>Things/Vehicles/LemanRuss/MainTurret/GW_HOI_LemanRuss_MainTurret_BattleCannon</texPath>
			<graphicClass>Vehicles.Graphic_Turret</graphicClass>
			<shaderType>CutoutComplexPattern</shaderType>
			<drawSize>(8, 8)</drawSize>
		</graphicData>
		<ammunition>
			<thingDefs>
				<li>GW_BattleCannonShellNonCE</li>
			</thingDefs>
		</ammunition>
		<motes>
